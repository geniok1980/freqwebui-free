{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@mastra/core": ["src/types/mastra-core.ts"],
      "@mastra/core/agent": ["src/types/mastra-core-agent.ts"],
      "@mastra/core/workflows": ["src/types/mastra-core-workflows.ts"],
      "zod": ["src/types/zod.ts"]
    },
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
